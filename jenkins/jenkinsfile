pipeline {
    agent any
    
    environment {
        DOCKER_REGISTRY = 'your-registry'
        IMAGE_NAME = 'ai-devsecops/threat-detector'
        IMAGE_TAG = "${BUILD_NUMBER}"
    }
    
    stages {

        stage('Install Security Tools') {
            steps {
                sh '''
                pip install bandit safety networkx scikit-learn
                curl -sSfL https://raw.githubusercontent.com/anchore/syft/main/install.sh | sh
                '''
            }
        }

        stage('Test') {
            steps {
                sh 'python -m pytest tests/'
            }
        }
        
        stage('Security Scan') {
            steps {
                sh 'bandit -r src/'
                sh 'safety check'
            }
        }

        // NEW STAGE 1
        stage('Generate SBOM') {
            steps {
                sh '''
                echo "Generating SBOM..."
                syft dir:. -o json > sbom.json
                '''
            }
        }

        // NEW STAGE 2
        stage('Build Dependency Graph') {
            steps {
                sh '''
                echo "Analyzing dependencies..."
                python3 src/supply_chain/dependency_graph.py
                '''
            }
        }

        // NEW STAGE 3
        stage('Supply Chain AI Security Check') {
            steps {
                sh '''
                echo "Running AI supply chain detection..."
                python3 src/supply_chain/pipeline_gate.py
                '''
            }
        }
        
        stage('Build & Push') {
            steps {
                script {
                    def customImage = docker.build("${DOCKER_REGISTRY}/${IMAGE_NAME}:${IMAGE_TAG}")

                    docker.withRegistry("https://${DOCKER_REGISTRY}", 'registry-credentials') {
                        customImage.push()
                    }
                }
            }
        }
        
        stage('Deploy') {
            steps {
                sh """
                    kubectl apply -f deploy/kubernetes/threat-detector.yaml
                    
                    kubectl set image deployment/threat-detector \
                    threat-detector=${DOCKER_REGISTRY}/${IMAGE_NAME}:${IMAGE_TAG}
                """
            }
        }
    }
}
